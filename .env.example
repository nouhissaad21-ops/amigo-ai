NODE_ENV=development
PORT=4000
TRUST_PROXY_HOPS=1
WEB_ORIGIN=http://localhost:3000
API_PUBLIC_URL=http://localhost:4000
INTERNAL_API_URL=http://api:4000
LOG_LEVEL=info
POSTGRES_DB=amigo
POSTGRES_ADMIN_PASSWORD=replace-with-a-long-admin-password
AMIGO_SYSTEM_PASSWORD=replace-with-a-long-system-password
AMIGO_APP_PASSWORD=replace-with-a-long-tenant-password
# Render/Neon generates this and derives DATABASE_TENANT_URL automatically:
# AMIGO_TENANT_PASSWORD=replace-with-at-least-32-random-characters
DATABASE_URL=postgresql://amigo_system:replace-with-a-long-system-password@localhost:5432/amigo?schema=public
DATABASE_TENANT_URL=postgresql://amigo_app:replace-with-a-long-tenant-password@localhost:5432/amigo?schema=public
REDIS_URL=redis://localhost:6379
CREDENTIAL_ENCRYPTION_KEY=replace-with-base64-encoded-32-byte-key
JWT_SECRET=replace-with-at-least-32-random-characters
OAUTH_STATE_SECRET=replace-with-another-32-character-secret
COOKIE_SECURE=false
RUN_INBOUND_WORKER=false
WORKER_CONCURRENCY=12
SERVE_STATIC_WEB=false
STATIC_WEB_DIR=apps/web/out
ENABLE_BAILEYS=true
AI_PROVIDER=groq
AI_TIMEOUT_MS=45000
GROQ_API_KEY=replace-with-a-new-groq-api-key
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile
# To use real Grok instead, set AI_PROVIDER=xai and uncomment XAI_API_KEY.
# XAI_API_KEY=replace-with-a-new-xai-api-key
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4.5
XAI_STORE_RESPONSES=false
# Meta is optional until you are ready to connect Facebook/Instagram/WhatsApp.
# META_APP_ID=replace-with-meta-app-id
# META_APP_SECRET=replace-with-meta-app-secret
META_VERIFY_TOKEN=replace-with-a-random-webhook-verify-token
META_GRAPH_VERSION=v25.0
META_OAUTH_REDIRECT_URI=http://localhost:4000/api/integrations/meta/callback
